APP_NAME=Gerador de Relatórios
APP_VERSION=1.0.0
DEBUG=false

MAX_FILE_SIZE=52428800

ALLOWED_EXTENSIONS=[".pdf", ".docx", ".xlsx", ".csv", ".pptx", ".txt", ".md"]

# === Configuração Inteligente de Modelos ===
# O sistema seleciona automaticamente:
# - MiniMax: tarefas simples (análise, validação)
# - GPT-4o-mini: tarefas médias
# - GPT-4o: tarefas complexas (FINEP, científico)

# Provider principal (usado como fallback)
LLM_PROVIDER=openai

# === OpenAI ===
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_COMPLEX=gpt-4o

# === MiniMax (para tarefas simples) ===
LLM_API_KEY=your_minimax_api_key_here
LLM_BASE_URL=https://api.minimax.chat/v1

TEMPERATURE=0.7
MAX_TOKENS=8192

SECURITY_ENABLE_GUARDRAILS=true
SECURITY_MAX_INPUT_LENGTH=500000

LOG_LEVEL=INFO
LOG_FORMAT=json

CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]
